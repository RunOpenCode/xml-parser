{
    "name": "runopencode/xml-parser",
    "description": "Library that enables fast, low memory footprint, parsing of large XML documents in developer friendly manner.",
    "license": "MIT",
    "authors": [
        {
            "name": "Nikola Svitlica a.k.a TheCelavi",
            "email": "thecelavi@runopencode.com"
        }
    ],
    "require": {
        "php": ">=8.4",
        "ext-dom": "*",
        "ext-libxml": "*",
        "ext-xml": "*",
        "ext-xmlreader": "*",
        "psr/http-message": "^2.0",
        "runopencode/stream": "^0.1.49"
    },
    "autoload": {
        "psr-4": {
            "RunOpenCode\\Component\\XmlParser\\": "src"
        }
    },
    "config": {
        "sort-packages": true
    },
    "version": "0.1.49",
    "minimum-stability": "dev",
    "prefer-stable": true
}
